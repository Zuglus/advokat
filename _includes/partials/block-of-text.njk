{% macro renderText(items) %}
  {% for item in items %}
    <p class="text-paragraph{% if item.variant == 'subtitle2' %} text-subtitle{% elif item.variant == 'body2' %} text-body2{% elif item.variant == 'overline' %} text-overline{% endif %}"
       style="text-align: {{ item.align | default('left') }}{% if item.textDecoration %}; text-decoration: {{ item.textDecoration }}{% endif %}">
      {% if item.paragraphBefore %}
        {{ item.paragraphBefore }}
        <a href="{{ item.linkHref }}"
           {% if item.target %}target="{{ item.target }}"{% endif %}
           {% if item.download %}download{% endif %}
           class="text-link">{{ item.linkName }}</a>
        {{ item.paragraphAfter }}
      {% else %}
        {{ item.paragraph }}
      {% endif %}
    </p>
  {% endfor %}
{% endmacro %}
